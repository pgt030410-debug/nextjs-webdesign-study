# Database connection string (Supabase/PostgreSQL)
# Replace placeholders with your actual Supabase credentials
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@your_host.pooler.supabase.com:6543/postgres

# Security settings
JWT_SECRET_KEY=generate_a_random_32_character_string_for_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
